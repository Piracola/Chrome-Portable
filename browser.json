{
  "release": {
    "tag_target": "chrome_stable",
    "tag": "v{chrome_stable_version}",
    "title": "Chrome++ {chrome_stable_version}",
    "body": "Chrome++ 构建版本\n\n构建时间: {date}\nStable 版本: {chrome_stable_version}\nBeta 版本: {chrome_beta_version}\n"
  },
  "targets": {
    "chrome_stable": {
      "name": "Chrome",
      "display_name": "Chrome++",
      "output_dir": "Chrome",
      "exe_name": "chrome.exe",
      "architecture": "x64",
      "env_prefix": "STABLE",
      "provider": {
        "type": "script",
        "command": ["python", "scripts/chrome_package.py", "--channel", "stable"]
      },
      "version_root": "Chrome-bin",
      "layout": "move_version_root",
      "chrome_plus_dir": "chrome++",
      "ini_location": "app_root",
      "version_dll_location": "app_root",
      "start_script": "开始.bat",
      "archive_name": "Chrome++_stable_{version}_{date}.7z",
      "release": {
        "asset_match": "stable",
        "version_pattern": "Stable\\s*版本[:：]\\s*(\\d+\\.\\d+\\.\\d+\\.\\d+)"
      }
    },
    "chrome_beta": {
      "name": "Chrome",
      "display_name": "Chrome++ Beta",
      "output_dir": "Chrome",
      "exe_name": "chrome.exe",
      "architecture": "x64",
      "env_prefix": "BETA",
      "provider": {
        "type": "script",
        "command": ["python", "scripts/chrome_package.py", "--channel", "beta"]
      },
      "version_root": "Chrome-bin",
      "layout": "move_version_root",
      "chrome_plus_dir": "chrome++",
      "ini_location": "app_root",
      "version_dll_location": "app_root",
      "start_script": "开始.bat",
      "archive_name": "Chrome++_beta_{version}_{date}.7z",
      "release": {
        "asset_match": "beta",
        "version_pattern": "Beta\\s*版本[:：]\\s*(\\d+\\.\\d+\\.\\d+\\.\\d+)"
      }
    }
  }
}
